  <rect x="80" y="420" width="200" height="4" rx="2" fill="#2563EB"/>
  <text x="80" y="480" font-family="Arial,sans-serif" font-size="18" fill="#94A3B8">What changed  ·  Who was affected  ·  How to recover</text>
