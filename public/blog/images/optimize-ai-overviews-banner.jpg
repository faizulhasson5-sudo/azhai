<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0F172A"/>
      <stop offset="50%" style="stop-color:#1E293B"/>
      <stop offset="100%" style="stop-color:#0F172A"/>
    </linearGradient>
    <linearGradient id="purple" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#8B5CF6"/>
      <stop offset="100%" style="stop-color:#A78BFA"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <circle cx="1050" cy="80" r="180" fill="#8B5CF6" opacity="0.05"/>
  <circle cx="80" cy="550" r="100" fill="#2563EB" opacity="0.04"/>
  <circle cx="600" cy="315" r="300" fill="#8B5CF6" opacity="0.02"/>
  <rect x="80" y="180" width="500" height="6" rx="3" fill="url(#purple)" opacity="0.5"/>
  <rect x="80" y="200" width="380" height="4" rx="2" fill="#475569" opacity="0.4"/>
  <rect x="80" y="218" width="440" height="4" rx="2" fill="#475569" opacity="0.25"/>
  <text x="80" y="110" font-family="Arial,sans-serif" font-size="22" fill="#64748B" font-weight="600" letter-spacing="2">SEO STRATEGY 2026</text>
  <text x="80" y="155" font-family="Arial,sans-serif" font-size="54" font-weight="bold" fill="white" letter-spacing="-1">How to Optimize</text>
  <text x="80" y="155" font-family="Arial,sans-serif" font-size="54" font-weight="bold" fill="white" dy="58" letter-spacing="-1">for Google AI Overviews</text>
  <g filter="url(#glow)">
    <text x="80" y="320" font-family="Arial,sans-serif" font-size="32" fill="#A78BFA" font-weight="700">Generative Engine Optimization</text>
    <text x="80" y="355" font-family="Arial,sans-serif" font-size="32" fill="#A78BFA" font-weight="700">(GEO)</text>
  </g>
  <rect x="80" y="385" width="200" height="4" rx="2" fill="#2563EB"/>
  <text x="80" y="430" font-family="Arial,sans-serif" font-size="17" fill="#94A3B8">1B+ AI Mode users · Conversational queries · Multimodal search</text>
  <rect x="80" y="470" width="180" height="44" rx="22" fill="url(#purple)"/>
  <text x="170" y="498" font-family="Arial,sans-serif" font-size="15" fill="white" text-anchor="middle" font-weight="600">Read the Guide</text>
  <rect x="820" y="120" width="300" height="380" rx="20" fill="#1E293B" stroke="#334155" stroke-width="2"/>
  <text x="970" y="180" font-family="Arial,sans-serif" font-size="15" fill="#64748B" text-anchor="middle" font-weight="600" letter-spacing="1">AI MODE STATS</text>
  <text x="970" y="250" font-family="Arial,sans-serif" font-size="52" fill="#A78BFA" text-anchor="middle" font-weight="bold">1B+</text>
  <text x="970" y="280" font-family="Arial,sans-serif" font-size="15" fill="#94A3B8" text-anchor="middle">Monthly Active Users</text>
  <rect x="870" y="300" width="200" height="1" fill="#334155"/>
  <text x="970" y="350" font-family="Arial,sans-serif" font-size="40" fill="#22C55E" text-anchor="middle" font-weight="bold">+40%</text>
  <text x="970" y="378" font-family="Arial,sans-serif" font-size="14" fill="#94A3B8" text-anchor="middle">Query Growth / Month</text>
  <rect x="870" y="395" width="200" height="1" fill="#334155"/>
  <text x="970" y="440" font-family="Arial,sans-serif" font-size="30" fill="#F59E0B" text-anchor="middle" font-weight="bold">1 in 6</text>
  <text x="970" y="465" font-family="Arial,sans-serif" font-size="13" fill="#94A3B8" text-anchor="middle">Searches Are Multimodal</text>
</svg>